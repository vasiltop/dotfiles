set $mod Mod4

# gaps
gaps inner 0
gaps outer 0

bindsym $mod+Shift+d gaps inner current set 0; gaps outer current set 0
bindsym $mod+Shift+s gaps inner current set 10; gaps outer current set 0

font pango:Iosevka 10

floating_modifier $mod

# screenshots
bindsym $mod+Shift+p exec maim -s -u | xclip -selection clipboard -t image/png -i

# startup
# exec --no-startup-id picom --config ~/.config/picom/picom.conf
exec_always --no-startup-id autotiling

# Use amixer to adjust volume in ALSA/Void Linux
bindsym XF86AudioRaiseVolume exec --no-startup-id amixer set Master 5%+
bindsym XF86AudioLowerVolume exec --no-startup-id amixer set Master 5%-
bindsym XF86AudioMute        exec --no-startup-id amixer set Master toggle

# start a terminal
bindsym $mod+Return exec --no-startup-id alacritty

# kill focused window
bindsym $mod+Shift+q kill

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# change layout of window
bindsym $mod+w layout tabbed
bindsym $mod+s layout toggle split

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# reload the configuration file
bindsym $mod+Shift+c reload
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart
# exit i3 (logs you out of your X session)
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"

# resize window
bindsym $mod+Shift+o resize shrink width 10 px or 10 ppt
bindsym $mod+Shift+i resize grow height 10 px or 10 ppt
bindsym $mod+Shift+u resize shrink height 10 px or 10 ppt
bindsym $mod+SHift+y resize grow width 10 px or 10 ppt

set $bg #121212

# current window is the lighter color
set $current_window #5b768d
set $other_window #46425e

set $text #fafbf6

# start dmenu
bindsym $mod+d exec --no-startup-id dmenu_run -c -l 15 -fn "Iosevka:size=11" -nb "$bg" -nf "$text" -sb "$current_window" -sf "$text"

# window colors
# border, background, text, bottom of the bar?
client.focused $current_window $current_window $text $current_window
client.focused_inactive $other_window $other_window $text $other_window
client.unfocused $other_window $other_window $text $other_window

# bg
exec_always --no-startup-id feh --bg-fill ~/.config/wallpapers/water.jpg

bar {
  status_command i3blocks
  position bottom
  separator_symbol "::"
  colors {
    background $bg
		statusline $text
    separator $text

		# border, background, text_color
		focused_workspace $current_window $current_window $text
    inactive_workspace $bg $bg $text
    active_workspace $bg $bg $text
    urgent_workspace $bg $bg $text
    binding_mode $bg $bg $text
  }
}
